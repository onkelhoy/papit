{
    "name": "@papit/root",
    "version": "0.0.0",
    "description": "A ecosystem designed to be generic and easy to extend. Intended use for creating packages in a monorepo setup",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/onkelhoy/papit.git"
    },
    "scripts": {
        "analyse": "to come",
        "publish": "to come",
        "prebuild": "node bin/prebuild.mjs",
        "clean": "node bin/clean.mjs",
        "build": "npx @papit/build --run --all",
        "test": "node bin/test.mjs",
        "create": "npm create @papit -- --package",
        "start": "npx @papit/server --serve --info",
        "dev": "npx @papit/server --serve --info --live"
    },
    "keywords": [
        "typescript"
    ],
    "packageManager": "npm@11.6.2",
    "engines": {
        "node": ">=20"
    },
    "author": "Henry Pap",
    "license": "LicenseRef-Papit-1.0",
    "workspaces": [
        "packages/**/*",
        "!packages/**/asset/**"
    ],
    "devDependencies": {
        "@papit/version": "0.0.1",
        "@papit/util": "0.0.1",
        "@papit/build": "0.0.1",
        "@papit/create": "0.0.1",
        "@microsoft/api-extractor": "^7.55.2",
        "esbuild": "^0.27.2",
        "typescript": "^5.9.3"
    },
    "papit": {
        "htmlprefix": "pap"
    }
}