{
    "name": "@papit/test",
    "description": "A package for testing @papit packages, it will determine the correct testing tool like playwright for browser type packages and simple node test for node packages",
    "keywords": [
        "papit",
        "node",
        "typescript",
        "test"
    ],
    "version": "0.0.1",
    "scripts": {
        "build": "npx @papit/build -- --run",
        "watch": "tsc -w",
        "start": "npm run build -- --dev && node ./lib/bundle.js",
        "test": "node --test",
        "preversion": "papit-version",
        "postversion": "papit-version",
        "component": "npm create @papit -- --component"
    },
    "main": "./lib/bundle.js",
    "types": "./lib/bundle.d.ts",
    "type": "module",
    "files": [
        "asset/",
        "lib/"
    ],
    "exports": {
        ".": {
            "import": "./lib/bundle.js",
            "types": "./lib/bundle.d.ts"
        }
    },
    "bin": {
        "papit-test": "./lib/bundle.js"
    },
    "author": "henry",
    "private": false,
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "license": "LicenseRef-Papit-1.0",
    "homepage": "https://github.com/onkelhoy/papit/tree/main/packages/runtime/cli/test",
    "bugs": {
        "url": "https://github.com/onkelhoy/papit/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/onkelhoy/papit.git",
        "directory": "packages/runtime/cli/test"
    },
    "sideEffects": true,
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "@papit/util": "^0.0.1",
        "@playwright/test": "^1.57.0"
    },
    "devDependencies": {
        "@types/node": "^22.10.2",
        "typescript": "^5.9.3"
    },
    "browserslist": [
        "defaults",
        "not IE 11",
        "not dead"
    ],
    "papit": {
        "publish": true,
        "type": "node",
        "main": "test",
        "components": {
            "test": {
                "className": "Test",
                "htmlprefix": "pap"
            }
        }
    }
}