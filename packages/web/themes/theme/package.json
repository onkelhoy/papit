{
    "name": "@papit/theme",
    "description": "core theme for the papit design-system",
    "keywords": [
        "papit",
        "typescript",
        "theme"
    ],
    "version": "0.0.1",
    "scripts": {
        "watch": "tsc -w",
        "start": "npx @papit/server --info --live",
        "test": "npx playwright test -c tests/playwright.config.ts $@",
        "preversion": "papit-version",
        "postversion": "papit-version",
        "component": "npm create @papit -- --component",
        "test:update-snapshots": "npx playwright test --update-snapshots -c tests/playwright.config.ts",
        "test:chrome": "npm test -- --project=chromium"
    },
    "type": "module",
    "files": [
        "asset/",
        "lib/"
    ],
    "style": "./lib/theme.css",
    "exports": {
        ".": "./lib/theme.css",
        "./theme.css": "./lib/theme.css"
    },
    "author": "henry",
    "private": false,
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "license": "LicenseRef-Papit-1.0",
    "homepage": "https://github.com/onkelhoy/papit/tree/main/packages/web/themes/theme",
    "bugs": {
        "url": "https://github.com/onkelhoy/papit/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/onkelhoy/papit.git",
        "directory": "packages/web/themes/theme"
    },
    "sideEffects": true,
    "engines": {
        "node": ">=18"
    },
    "dependencies": {},
    "devDependencies": {
        "@playwright/test": "1.58.0",
        "playwright": "1.58.0",
        "typescript": "5.9.3",
        "@papit/translator": "*",
        "@papit/codeblock": "*"
    },
    "browserslist": [
        "defaults",
        "not IE 11",
        "not dead"
    ],
    "papit": {
        "publish": true,
        "type": "theme",
        "main": "theme",
        "components": {
            "theme": {
                "className": "Theme",
                "htmlprefix": "pap"
            }
        }
    }
}