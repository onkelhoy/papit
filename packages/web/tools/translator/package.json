{
    "name": "@papit/translator",
    "description": "Simple translation utility with lazy fetch, variable interpolation, and auto language detection",
    "keywords": [
        "papit",
        "browser",
        "typescript",
        "translator"
    ],
    "version": "0.0.1",
    "scripts": {
        "build": "npx @papit/build --error",
        "watch": "tsc -w",
        "start": "npx @papit/server --info --live",
        "test": "npx playwright test -c tests/playwright.config.ts $@",
        "preversion": "papit-version",
        "postversion": "papit-version",
        "component": "npm create @papit --component",
        "test:update-snapshots": "npx playwright test --update-snapshots -c tests/playwright.config.ts",
        "test:chrome": "npm test -- --project=chromium",
        "build:react": "bash ./bin/_utils/react.sh"
    },
    "main": "./lib/browser.js",
    "types": "./lib/browser.d.ts",
    "type": "module",
    "files": [
        "asset/",
        "lib/"
    ],
    "exports": {
        ".": {
            "import": "./lib/browser.js",
            "types": "./lib/browser.d.ts"
        },
        "./browser": {
            "import": "./lib/browser.js",
            "types": "./lib/browser.d.ts"
        },
        "./node": {
            "import": "./lib/node.js",
            "types": "./lib/node.d.ts"
        }
    },
    "author": "henry",
    "private": false,
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "license": "LicenseRef-Papit-1.0",
    "homepage": "https://github.com/onkelhoy/papit/tree/main/packages/web/tools/translator",
    "bugs": {
        "url": "https://github.com/onkelhoy/papit/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/onkelhoy/papit.git",
        "directory": "packages/web/tools/translator"
    },
    "sideEffects": true,
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "@papit/signals": "^0.0.1"
    },
    "devDependencies": {
        "@papit/theme": "^0.0.1",
        "@playwright/test": "1.58.0",
        "playwright": "1.58.0",
        "typescript": "5.9.3",
        "@papit/codeblock": "*"
    },
    "browserslist": [
        "defaults",
        "not IE 11",
        "not dead"
    ],
    "papit": {
        "publish": true,
        "type": {
            "./browser": "browser",
            "./node": "node"
        },
        "main": "translator",
        "htmlprefix": "pap",
        "components": {
            "translator": {
                "className": "Translator",
                "htmlprefix": "pap"
            }
        }
    }
}